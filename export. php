<?php
require 'vendor/autoload.php';
use PhpOffice\PhpSpreadsheet\Spreadsheet;
use PhpOffice\PhpSpreadsheet\Writer\Xlsx;

$file = 'receipts.json';
$data = json_decode(file_get_contents($file), true);

$spreadsheet = new Spreadsheet();
$sheet = $spreadsheet->getActiveSheet();
$sheet->fromArray(['Receipt Number','Date','Customer','Phone','Services','Total'], NULL, 'A1');

$row = 2;
foreach ($data as $receipt) {
  $services = implode(", ", array_map(fn($s) => $s[0], $receipt['services']));
  $sheet->fromArray([$receipt['receipt_number'],$receipt['date'],$receipt['customer'],$receipt['phone'],$services,$receipt['total']], NULL, "A$row");
  $row++;
}

foreach (range('A', 'F') as $col) {
  $sheet->getColumnDimension($col)->setAutoSize(true);
}

$writer = new Xlsx($spreadsheet);
header('Content-Type: application/vnd.openxmlformats-officedocument.spreadsheetml.sheet');
header('Content-Disposition: attachment;filename="receipts_' . date('Y-m-d') . '.xlsx"');
$writer->save('php://output');
?>